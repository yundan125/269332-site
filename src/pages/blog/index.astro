---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION } from '../../consts';
import { getPublishedPosts } from '../../utils/posts';

const posts = await getPublishedPosts();
---

<BaseLayout title="博客 · 269332" description={SITE_DESCRIPTION}>
	<main class="blog-index">
		<header class="page-heading">
			<p>博客</p>
			<h1>文章</h1>
			<span>按发布时间倒序展示已发布内容。</span>
		</header>

		{posts.length > 0 ? (
			<ul class="post-list">
				{posts.map((post) => (
					<li>
						<a href={'/blog/' + post.id + '/'}>
							{post.data.heroImage && (
								<Image width={720} height={360} src={post.data.heroImage} alt="" />
							)}
							<div>
								<h2>{post.data.title}</h2>
								<p>{post.data.description}</p>
								<FormattedDate date={post.data.pubDate} />
							</div>
						</a>
					</li>
				))}
			</ul>
		) : (
			<section class="empty-state">
				<h2>文章正在整理</h2>
				<p>官方示例文章已隐藏。真实文章发布后会显示在这里，并同步进入 RSS。</p>
			</section>
		)}
	</main>
</BaseLayout>

<style>
	.blog-index {
		width: min(960px, calc(100% - 2rem));
		max-width: none;
	}
	.page-heading {
		margin-bottom: 2.5rem;
	}
	.page-heading p,
	.page-heading span {
		margin: 0;
		color: rgb(var(--gray));
	}
	.post-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.post-list li:first-child {
		grid-column: 1 / -1;
	}
	.post-list a {
		display: block;
		height: 100%;
		overflow: hidden;
		background: white;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 14px;
		color: inherit;
		text-decoration: none;
	}
	.post-list img {
		width: 100%;
		border-radius: 0;
	}
	.post-list a > div {
		padding: 1.25rem;
	}
	.post-list h2 {
		margin-bottom: 0.5rem;
		font-size: 1.4rem;
	}
	.post-list p {
		color: rgb(var(--gray));
	}
	.post-list a:hover {
		border-color: var(--accent);
		box-shadow: 0 8px 24px rgba(var(--gray), 18%);
	}
	.empty-state {
		padding: 2rem;
		background: white;
		border: 1px dashed rgb(var(--gray));
		border-radius: 14px;
		text-align: center;
	}
	.empty-state p {
		margin-bottom: 0;
		color: rgb(var(--gray));
	}
	@media (max-width: 720px) {
		.post-list {
			grid-template-columns: 1fr;
		}
	}
</style>
