---
import CatalogCard from '../../components/CatalogCard.astro';
import { projects } from '../../data/catalog';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="项目 · 269332" description="个人项目与开发记录。">
	<main class="catalog-page">
		<header>
			<div>
				<p class="eyebrow">项目</p>
				<h1>项目与开发记录</h1>
				<p>展示已经确认的真实项目、当前状态和主要技术方向。</p>
			</div>
			<p class="count">{projects.length} 个项目</p>
		</header>
		<section class="catalog-grid" aria-label="项目列表">
			{projects.map((project) => <CatalogCard item={project} />)}
		</section>
	</main>
</BaseLayout>

<style>
	.catalog-page {
		width: min(1040px, calc(100% - 2rem));
		max-width: none;
	}
	header {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 2rem;
		margin-bottom: 2.5rem;
	}
	.eyebrow {
		margin: 0 0 0.5rem;
		color: var(--accent-dark);
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.14em;
	}
	header div > p:last-child,
	.count {
		margin-bottom: 0;
		color: rgb(var(--gray));
	}
	.count {
		flex: 0 0 auto;
		font-size: 0.85rem;
	}
	.catalog-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}
	@media (max-width: 720px) {
		header {
			display: block;
		}
		.count {
			margin-top: 1rem;
		}
		.catalog-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
