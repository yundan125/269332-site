---
import CatalogCard from '../../components/CatalogCard.astro';
import { overwatchTools } from '../../data/catalog';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
	title="守望先锋工具箱 · 269332"
	description="浏览 269332 收录的守望先锋赛事预测、英雄猜名和其他交互工具。"
>
	<main class="catalog-page">
		<header>
			<div>
				<p class="eyebrow">守望先锋</p>
				<h1>守望先锋工具箱</h1>
				<p>收录围绕《守望先锋》制作的赛事预测、英雄猜名和其他网页工具。</p>
			</div>
			<p class="count"><strong>{overwatchTools.length}</strong> 个守望先锋工具</p>
		</header>
		<section class="catalog-grid" aria-label="守望先锋工具列表">
			{overwatchTools.map((tool) => <CatalogCard item={tool} />)}
		</section>
		<aside class="copyright-note" aria-label="守望先锋版权与非官方说明">
			《守望先锋》及相关角色、美术素材版权归 Blizzard Entertainment 所有。本站收录的相关工具用于个人学习和非商业娱乐，与 Blizzard Entertainment 无官方关联。
		</aside>
	</main>
</BaseLayout>

<style>
	.catalog-page {
		width: min(var(--content-width), calc(100% - 2rem));
		max-width: none;
	}
	header {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 2rem;
		margin-bottom: 2.5rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--color-border);
	}
	header h1 {
		font-size: clamp(2.25rem, 6vw, 3.75rem);
	}
	header div > p:last-child,
	.count {
		margin-bottom: 0;
		color: var(--color-text-muted);
	}
	.count {
		flex: 0 0 auto;
		font-size: 0.82rem;
	}
	.count strong {
		color: var(--color-text);
		font-size: 1.25rem;
	}
	.catalog-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.copyright-note {
		margin-top: 2rem;
		padding: 1rem 1.1rem;
		background: var(--color-surface-muted);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-small);
		color: var(--color-text-muted);
		font-size: 0.78rem;
	}
	@media (max-width: 720px) {
		.catalog-page {
			width: min(var(--content-width), calc(100% - 1.5rem));
		}
		header {
			display: block;
		}
		.count {
			margin-top: 1rem;
		}
		.catalog-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
