---
import CatalogCard from '../../components/CatalogCard.astro';
import { tools } from '../../data/catalog';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="工具箱 · 269332" description="网页工具与功能导航。">
	<main class="catalog-page">
		<header>
			<div>
				<p class="eyebrow">工具箱</p>
				<h1>网页工具与功能导航</h1>
				<p>收录可以直接使用或通过独立仓库访问的网页工具。</p>
			</div>
			<p class="count">{tools.length} 个工具</p>
		</header>
		<section class="catalog-grid" aria-label="工具列表">
			{tools.map((tool) => <CatalogCard item={tool} />)}
		</section>
	</main>
</BaseLayout>

<style>
	.catalog-page {
		width: min(1040px, calc(100% - 2rem));
		max-width: none;
	}
	header {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 2rem;
		margin-bottom: 2.5rem;
	}
	.eyebrow {
		margin: 0 0 0.5rem;
		color: var(--accent-dark);
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.14em;
	}
	header div > p:last-child,
	.count {
		margin-bottom: 0;
		color: rgb(var(--gray));
	}
	.count {
		flex: 0 0 auto;
		font-size: 0.85rem;
	}
	.catalog-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}
	@media (max-width: 720px) {
		header {
			display: block;
		}
		.count {
			margin-top: 1rem;
		}
		.catalog-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
