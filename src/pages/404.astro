---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到 · 269332" description="请求的页面不存在。">
	<main class="not-found">
		<p class="code">404</p>
		<h1>页面未找到</h1>
		<p>这个地址不存在，或者页面尚未发布。</p>
		<a href="/">返回首页</a>
	</main>
</BaseLayout>

<style>
	.not-found {
		min-height: 55vh;
		text-align: center;
	}
	.code {
		margin: 0;
		color: var(--accent);
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.2em;
	}
	.not-found > p:not(.code) {
		color: rgb(var(--gray));
	}
</style>
