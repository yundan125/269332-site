---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到 · 269332" description="请求的页面不存在。">
	<main class="not-found">
		<div aria-hidden="true">404</div>
		<p class="eyebrow">页面未找到</p>
		<h1>这里没有对应内容</h1>
		<p>地址可能已经变化，或者页面暂时没有公开。</p>
		<div class="actions">
			<a class="button button-primary" href="/">返回首页</a>
			<a class="button button-secondary" href="/projects/">查看项目</a>
		</div>
	</main>
</BaseLayout>

<style>
	.not-found {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 65vh;
		text-align: center;
	}
	.not-found > div:first-child {
		color: var(--color-accent-soft);
		font-size: clamp(6rem, 24vw, 13rem);
		font-weight: 700;
		line-height: 0.75;
		letter-spacing: -0.08em;
	}
	.not-found h1 {
		font-size: clamp(2rem, 6vw, 3.25rem);
	}
	.not-found > p:not(.eyebrow) {
		color: var(--color-text-muted);
	}
	.actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.75rem;
		margin-top: 1rem;
	}
</style>
