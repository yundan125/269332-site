---
import FeaturedCatalog from '../components/home/FeaturedCatalog.astro';
import FocusAreas from '../components/home/FocusAreas.astro';
import HomeHero from '../components/home/HomeHero.astro';
import HomeOverview from '../components/home/HomeOverview.astro';
import TechStack from '../components/home/TechStack.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { projects, tools } from '../data/catalog';
import BaseLayout from '../layouts/BaseLayout.astro';

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: SITE_TITLE,
	url: 'https://269332.xyz',
	description: SITE_DESCRIPTION,
};
---

<BaseLayout title="269332 · 项目与实用工具" description={SITE_DESCRIPTION}>
	<script
		slot="head"
		is:inline
		type="application/ld+json"
		set:html={JSON.stringify(websiteSchema)}
	></script>
	<main class="home">
		<HomeHero />
		<HomeOverview projectsCount={projects.length} toolsCount={tools.length} />
		<FeaturedCatalog
			id="featured-projects"
			eyebrow="精选项目"
			title="正在维护的项目"
			description="从系统工具到源码补丁，这些项目都来自真实的使用需求，并持续在对应仓库中维护。"
			items={projects}
			allHref="/projects/"
			allLabel="查看全部项目"
		/>
		<FeaturedCatalog
			id="featured-tools"
			eyebrow="精选工具"
			title="可以继续使用和扩展的网页工具"
			description="面向具体场景制作，当前工具信息与源码入口均来自真实仓库。"
			items={tools}
			allHref="/tools/"
			allLabel="查看全部工具"
		/>
		<FocusAreas />
		<TechStack />
		<section class="about-callout" aria-labelledby="about-callout-title">
			<div>
				<p class="eyebrow">关于本站</p>
				<h2 id="about-callout-title">了解这个网站</h2>
				<p>269332 用于整理真实项目、实用工具和开发经验，并随着项目推进持续更新。</p>
			</div>
			<div class="callout-actions">
				<a class="button button-primary" href="/about/">关于本站</a>
				<a
					class="button button-secondary"
					href="https://github.com/yundan125"
					target="_blank"
					rel="noopener noreferrer"
				>
					GitHub <span aria-hidden="true">↗</span>
					<span class="sr-only">（在新窗口打开）</span>
				</a>
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.home {
		width: min(var(--content-width), calc(100% - 2rem));
		max-width: none;
		padding: 0 0 clamp(4rem, 8vw, 7rem);
	}
	.about-callout {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		margin-top: var(--section-space);
		padding: clamp(1.75rem, 4vw, 2.75rem);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-large);
		box-shadow: var(--shadow-small);
	}
	.about-callout > div:first-child {
		max-width: 42rem;
	}
	.about-callout p:last-child {
		margin: 0;
		color: var(--color-text-muted);
	}
	.callout-actions {
		display: flex;
		flex: 0 0 auto;
		gap: 0.75rem;
	}
	@media (max-width: 720px) {
		.home {
			width: min(var(--content-width), calc(100% - 1.5rem));
		}
		.about-callout {
			display: block;
		}
		.callout-actions {
			flex-wrap: wrap;
			margin-top: 1.5rem;
		}
	}
	@media (max-width: 420px) {
		.callout-actions .button {
			width: 100%;
		}
	}
</style>
