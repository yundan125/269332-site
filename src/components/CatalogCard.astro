---
import type { CatalogItem } from '../data/catalog';

interface Props {
	item: CatalogItem;
}

const { item } = Astro.props;
const isPrivate = item.visibility === 'private';
---

<article class="catalog-card">
	<div class="card-meta">
		<span>{item.category}</span>
		<span class="status">{item.status}</span>
		{isPrivate && <span class="private">私有仓库</span>}
	</div>
	<h2>{item.name}</h2>
	<p class="summary">{item.summary}</p>
	<ul class="tag-list" aria-label={item.name + ' 技术标签'}>
		{item.tags.map((tag) => <li>{tag}</li>)}
	</ul>
	<div class="card-footer">
		{isPrivate && <p>源代码仓库仅对已授权的 GitHub 账号开放。</p>}
		<div class="card-actions">
			{item.website && (
				<a class="website-link" href={item.website}>
					打开网页
					<span aria-hidden="true">→</span>
				</a>
			)}
			<a href={item.repository} target="_blank" rel="noopener noreferrer">
				{isPrivate ? '访问私有仓库' : '查看 GitHub 仓库'}
				<span aria-hidden="true">↗</span>
				<span class="sr-only">（在新窗口打开）</span>
			</a>
		</div>
	</div>
</article>

<style>
	.catalog-card {
		display: flex;
		flex-direction: column;
		min-width: 0;
		padding: 1.5rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-medium);
		box-shadow: var(--shadow-small);
	}
	.catalog-card:hover {
		border-color: rgba(36, 93, 168, 0.5);
		box-shadow: var(--shadow-medium);
		transform: translateY(-2px);
	}
	.card-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-bottom: 0.9rem;
	}
	.card-meta span {
		padding: 0.18rem 0.5rem;
		background: var(--color-surface-muted);
		border-radius: 999px;
		color: var(--color-text-muted);
		font-size: 0.68rem;
		font-weight: 700;
	}
	.card-meta .status {
		background: var(--color-success-soft);
		color: var(--color-success);
	}
	.card-meta .private {
		background: #fff0df;
		color: #8a4b0f;
	}
	h2 {
		margin-bottom: 0.7rem;
		font-size: 1.35rem;
		overflow-wrap: anywhere;
	}
	.summary {
		flex: 1;
		color: var(--color-text-muted);
		font-size: 0.9rem;
	}
	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin: 0 0 1.25rem;
		padding: 0;
		list-style: none;
	}
	.tag-list li {
		padding: 0.18rem 0.45rem;
		border: 1px solid var(--color-border);
		border-radius: 0.35rem;
		color: var(--color-text-muted);
		font-size: 0.68rem;
	}
	.card-footer {
		padding-top: 1rem;
		border-top: 1px solid var(--color-border);
	}
	.card-footer p {
		margin-bottom: 0.75rem;
		color: #8a4b0f;
		font-size: 0.76rem;
	}
	.card-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem 1rem;
	}
	.card-actions a {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.84rem;
		font-weight: 700;
		text-decoration: none;
	}
	.card-actions .website-link {
		padding: 0.35rem 0.65rem;
		background: var(--color-accent);
		border-radius: var(--radius-small);
		color: white;
	}
	.card-actions .website-link:hover {
		background: var(--color-accent-hover);
		color: white;
	}
	@media (prefers-reduced-motion: reduce) {
		.catalog-card:hover {
			transform: none;
		}
	}
</style>
