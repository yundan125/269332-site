---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav aria-label="主导航">
		<a class="brand" href="/" aria-label="269332 首页">
			<span aria-hidden="true">{SITE_TITLE}</span>
		</a>
		<div class="nav-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/tools">工具箱</HeaderLink>
			<HeaderLink href="/projects">项目</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>
		<a
			class="repo-link"
			href="https://github.com/yundan125"
			target="_blank"
			rel="noopener noreferrer"
		>
			GitHub
			<span aria-hidden="true">↗</span>
			<span class="sr-only">（在新窗口打开）</span>
		</a>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		margin: 0;
		padding: 0 1rem;
		background: rgba(248, 250, 252, 0.88);
		border-bottom: 1px solid rgba(220, 227, 235, 0.85);
		backdrop-filter: blur(16px);
	}
	nav {
		display: flex;
		align-items: center;
		gap: 1rem;
		width: min(var(--content-width), 100%);
		min-height: 4.5rem;
		margin: 0 auto;
	}
	.brand {
		flex: 0 0 auto;
		padding: 0.35rem 0;
		color: var(--color-text);
		font-size: 1.08rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-decoration: none;
	}
	.nav-links {
		display: flex;
		flex: 1;
		align-items: center;
		justify-content: center;
		gap: 0.25rem;
	}
	.nav-links :global(a) {
		padding: 0.55rem 0.8rem;
		border-radius: var(--radius-small);
		color: var(--color-text-muted);
		font-size: 0.9rem;
		font-weight: 600;
	}
	.nav-links :global(a:hover) {
		background: var(--color-surface-muted);
		color: var(--color-text);
	}
	.nav-links :global(a.active) {
		background: var(--color-accent-soft);
		color: var(--color-accent-hover);
	}
	.repo-link {
		display: inline-flex;
		flex: 0 0 auto;
		align-items: center;
		gap: 0.3rem;
		padding: 0.5rem 0.7rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-small);
		color: var(--color-text);
		font-size: 0.84rem;
		font-weight: 700;
		text-decoration: none;
	}
	.repo-link:hover {
		background: var(--color-surface);
		border-color: var(--color-accent);
		color: var(--color-accent-hover);
	}
	@media (max-width: 720px) {
		.site-header {
			padding: 0 0.75rem;
		}
		nav {
			display: grid;
			grid-template-columns: 1fr auto;
			gap: 0.4rem 0.75rem;
			padding: 0.65rem 0 0.45rem;
		}
		.nav-links {
			display: grid;
			grid-column: 1 / -1;
			grid-template-columns: repeat(4, minmax(0, 1fr));
			width: 100%;
			gap: 0.2rem;
		}
		.nav-links :global(a) {
			padding: 0.55rem 0.2rem;
			font-size: 0.8rem;
			text-align: center;
		}
		.repo-link {
			padding: 0.4rem 0.6rem;
		}
	}
</style>
