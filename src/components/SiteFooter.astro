---
import { SITE_TITLE } from '../consts';

const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-brand">
			<a href="/">{SITE_TITLE}</a>
			<p>记录开发、项目与实用工具。</p>
		</div>
		<nav aria-label="页脚导航">
			<p>站内导航</p>
			<a href="/">首页</a>
			<a href="/tools/">工具箱</a>
			<a href="/projects/">项目</a>
			<a href="/about/">关于</a>
		</nav>
		<div class="footer-links">
			<p>链接与技术</p>
			<a href="https://github.com/yundan125" target="_blank" rel="noopener noreferrer">
				GitHub<span class="sr-only">（在新窗口打开）</span>
			</a>
			<a
				href="https://github.com/yundan125/269332-site"
				target="_blank"
				rel="noopener noreferrer"
			>
				网站源码<span class="sr-only">（在新窗口打开）</span>
			</a>
			<span>由 Astro 构建</span>
			<span>部署于 Cloudflare</span>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {year} {SITE_TITLE}</p>
		<p>个人网站 · 内容随项目持续更新</p>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: 2rem;
		padding: 3.5rem 1rem 2rem;
		background: #101923;
		color: #bdc8d5;
	}
	.footer-inner,
	.footer-bottom {
		width: min(var(--content-width), 100%);
		margin: 0 auto;
	}
	.footer-inner {
		display: grid;
		grid-template-columns: minmax(0, 1.5fr) repeat(2, minmax(10rem, 0.75fr));
		gap: 2rem;
		padding-bottom: 2.5rem;
	}
	.footer-brand > a {
		color: white;
		font-size: 1.25rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-decoration: none;
	}
	.footer-brand p {
		max-width: 24rem;
		margin: 0.75rem 0 0;
	}
	nav,
	.footer-links {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.55rem;
	}
	nav p,
	.footer-links p {
		margin: 0 0 0.25rem;
		color: white;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
	}
	nav a,
	.footer-links a {
		color: #bdc8d5;
		text-decoration: none;
	}
	nav a:hover,
	.footer-links a:hover {
		color: white;
	}
	.footer-links span,
	nav a,
	.footer-links a {
		font-size: 0.88rem;
	}
	.footer-bottom {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding-top: 1.25rem;
		border-top: 1px solid rgba(255, 255, 255, 0.12);
		font-size: 0.78rem;
	}
	.footer-bottom p {
		margin: 0;
	}
	@media (max-width: 720px) {
		.site-footer {
			padding-top: 2.5rem;
		}
		.footer-inner {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
		.footer-brand {
			grid-column: 1 / -1;
		}
		.footer-bottom {
			display: block;
		}
		.footer-bottom p + p {
			margin-top: 0.35rem;
		}
	}
</style>
